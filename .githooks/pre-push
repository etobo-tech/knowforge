#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
REMOTE_REF="${1:-}"
LOCAL_REF="${2:-}"
REMOTE_SHA="${3:-}"
LOCAL_SHA="${4:-}"

should_run_back_quality() {
  if [[ -z "$REMOTE_SHA" || "$REMOTE_SHA" == "0000000000000000000000000000000000000000" ]]; then
    return 0
  fi

  if git diff --name-only "$REMOTE_SHA" "$LOCAL_SHA" | grep -qE '^(back/|\.githooks/|scripts/back-quality\.sh)'; then
    return 0
  fi

  return 1
}

while read -r remote_ref local_ref remote_sha local_sha; do
  if should_run_back_quality "$remote_ref" "$local_ref" "$remote_sha" "$local_sha"; then
    exec "$ROOT/scripts/back-quality.sh"
  fi
done

exit 0
